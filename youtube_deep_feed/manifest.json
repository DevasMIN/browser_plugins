{
  "manifest_version": 3,
  "name": "YouTube Deep Feed",
  "version": "0.9.15",
  "key": "",
  "description": "Собственная бесконечная хронологическая лента по всем подпискам: локальный кэш, скрытие видео/каналов, автоотметка просмотренного из истории YouTube",
  "permissions": ["storage", "unlimitedStorage", "cookies", "tabs", "declarativeNetRequestWithHostAccess"],
  "host_permissions": ["*://www.youtube.com/*"],
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "Открыть глубокую ленту подписок" },
  "commands": {
    "open-feed": {
      "suggested_key": { "default": "Ctrl+Shift+Y" },
      "description": "Открыть глубокую ленту подписок"
    }
  },
  "web_accessible_resources": [
    { "resources": ["feed.html"], "matches": ["<all_urls>"] }
  ],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["relay.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
