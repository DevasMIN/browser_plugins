{
  "manifest_version": 3,
  "name": "YouTube Subscriptions – Hide WorkshopCinemaHD",
  "version": "1.0",
  "description": "Скрывает видео от канала @WorkshopCinemaHD в ленте подписок YouTube",
  "permissions": [],
  "host_permissions": [
    "*://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
